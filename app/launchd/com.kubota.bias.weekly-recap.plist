<plist version="1.0">
<dict>
  <key>Label</key><string>com.kubota.bias.weekly-recap</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Users/kubota/Desktop/bias/app/scripts/weekly_runner.sh</string>
    <string>weekly_recap</string>
  </array>
  <key>StartCalendarInterval</key>
